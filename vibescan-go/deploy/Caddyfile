# Caddy fronts the Go app and handles TLS automatically for {$DOMAIN}.
# Set DOMAIN in .env to your real hostname for auto-HTTPS (DNS must point here,
# ports 80/443 open). Use DOMAIN=:80 for a local, HTTP-only test.

{$DOMAIN} {
	encode zstd gzip
	log

	# Security headers (applied to all responses, including reverse-proxied ones).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# Images may load from the public capture CDN (img.* / CloudFront).
		Content-Security-Policy "default-src 'self'; img-src 'self' https: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; font-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
		-Server
	}

	# Fingerprinted Vite assets — long cache.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	reverse_proxy app:8000
}
