# Copy to agent.env and fill in. Runs on the scanner host.
# See deploy/DEPLOY.md §7 for the full scanner runbook.

# Your collector (the live server), no trailing path:
VIBESCAN_SERVER_URL=https://YOUR_DOMAIN
# MUST match the collector's VIBESCAN_SHARED_KEY, or submissions are rejected.
VIBESCAN_SHARED_KEY=change-me-to-match-the-collector

# Ports to scan and nmap timing (polite to start; code default is -n -T3 if unset).
VIBESCAN_PORTS=80,8080,8000
VIBESCAN_NMAP_OPTIONS=-n -T2

# Concurrency — raise on a larger scanner host, keep modest on a small VPS.
VIBESCAN_SCAN_THREADS=4          # concurrent host record builds
VIBESCAN_BATCH_SIZE=10           # random IPs per nmap batch
VIBESCAN_BROWSER_CONCURRENCY=2   # concurrent headless Chromium captures
VIBESCAN_CAPTURE_DELAY=2.0       # seconds to let a page settle before screenshot

# Capture screenshots (1) or discover-only, banners without images (0).
VIBESCAN_CAPTURE_HTTP=1

# Redact submitter IP in Mongo + public APIs (submitted_by → 0.0.0.0, anon=true).
# Does not hide your egress IP from scan targets. Recommended when using personal egress.
VIBESCAN_NO_REPORT=1
