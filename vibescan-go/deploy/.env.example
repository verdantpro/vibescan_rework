# Copy to .env and fill in. Never commit the real .env.
# Full runbook: deploy/DEPLOY.md

# --- Registry deploy only (docker-compose.registry.yml) ---
# The image pushed by build-push.sh. Not needed for the build-on-server compose.
#IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/vibescan:20260722-120000

# --- Public site (Caddy + app) ---
# Real domain for automatic HTTPS (DNS must point at this host; 80/443 open).
# For a local HTTP-only smoke test use  DOMAIN=:80
DOMAIN=your-domain.com
VIBESCAN_PUBLIC_URL=https://your-domain.com

# --- Shared HMAC key between the scanning agents and the collector ---
# Generate a long random value, e.g.  openssl rand -hex 32
VIBESCAN_SHARED_KEY=change-me-to-a-long-random-secret

# --- MongoDB Atlas ---
MONGO_URI=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=vibescan
MONGO_COLLECTION=results

# --- Amazon S3 + CloudFront (screenshots) ---
# (These S3_* names also accept the legacy R2_* equivalents if you ever switch.)
S3_ENABLED=1
S3_BUCKET_NAME=vibescan-captures
S3_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com
S3_REGION=us-east-1                       # required for AWS S3 (SigV4 signing)
S3_ACCESS_KEY_ID=your-s3-access-key       # IAM user with s3:PutObject on the bucket
S3_SECRET_ACCESS_KEY=your-s3-secret-key
# CloudFront distribution domain (or a custom domain in front of it). No trailing slash.
S3_PUBLIC_URL=https://dxxxxxxxxxxxxx.cloudfront.net
# If an upload fails, keep the base64 capture in Mongo instead of dropping it.
S3_FALLBACK_TO_MONGO=1

# Optional: per-IP rate limit for the public /api/v2 read endpoints.
# RPS is tokens refilled per second; BURST is the bucket size (short spikes).
# Set RPS to 0 to disable limiting entirely. Defaults: 10 / 20.
#VIBESCAN_READ_RATE_RPS=10
#VIBESCAN_READ_RATE_BURST=20

# Optional: verbose ingest logging (recreate the app container after changing).
#VIBESCAN_DEBUG=1
